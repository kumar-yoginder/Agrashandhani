# Agrashandhani OSINT Tool - Configuration Template
# Copy this file to .env and fill in your actual API keys
# Do NOT commit .env file to version control (it contains secrets)

# =====================================================
# VirusTotal API
# =====================================================
# Get your API key from: https://www.virustotal.com/gui/my-apikey
VT_API_KEY=your_virustotal_api_key_here

# =====================================================
# MalwareBazaar API
# =====================================================
# Get your API key from: https://auth.abuse.ch/
MB_API_KEY=your_malwarebazaar_api_key_here

# =====================================================
# Hybrid Analysis API
# =====================================================
# Get your API key from: https://www.hybrid-analysis.com/
HA_API_KEY=your_hybrid_analysis_api_key_here

# =====================================================
# MalShare API
# =====================================================
# Get your API key from: https://malshare.com/register.php
MALSHARE_API_KEY=your_malshare_api_key_here

# =====================================================
# AlienVault OTX API
# =====================================================
# Get your API key from: https://otx.alienvault.com/account/profile
OTX_API_KEY=your_otx_api_key_here

# =====================================================
# MetaDefender (OPSWAT) API
# =====================================================
# Get your API key from: https://dashboard.metadefender.com/
OPSWAT_API_KEY=your_opswat_metadefender_api_key_here

# =====================================================
# Team Cymru Hash/IP Reputation API
# =====================================================
# Register at: https://hash.cymru.com/
# API documentation: https://hash.cymru.com/docs_rest
CYMRU_API_USERNAME=your_cymru_username_here
CYMRU_API_PASSWORD=your_cymru_password_here

# =====================================================
# Any.run Sandbox / Threat Intelligence API
# =====================================================
# Register at: https://app.any.run/
# API documentation: https://any.run/api-documentation/#ti-lookup
ANYRUN_API_KEY=your_anyrun_api_key_here

# =====================================================
# SecurityTrails API
# =====================================================
# Register at: https://securitytrails.com/app/account/credentials
# API documentation: https://docs.securitytrails.com/reference
SECURITYTRAILS_API_KEY=your_securitytrails_api_key_here

# =====================================================
# Shodan API
# =====================================================
# Register at: https://account.shodan.io/
# API documentation: https://developer.shodan.io/api
SHODAN_API_KEY=your_shodan_api_key_here

# =====================================================
# GreyNoise Community API
# =====================================================
# Register at: https://www.greynoise.io/account/signup
# API documentation: https://docs.greynoise.io/reference/get_v3-community-ip
GREYNOISE_API_KEY=your_greynoise_api_key_here

# =====================================================
# IBM X-Force Exchange API
# =====================================================
# Register at: https://exchange.xforce.ibmcloud.com/settings/api
# API documentation: https://api.xforce.ibmcloud.com/doc/
XFORCE_API_KEY=your_xforce_api_key_here
XFORCE_API_PASSWORD=your_xforce_api_password_here

# =====================================================
# Optional: Proxy Settings
# =====================================================
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# =====================================================
# Optional: Database Settings
# =====================================================
# DB_FILE=threat_intel_db.json
# HTTP_TIMEOUT=20
